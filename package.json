{
  "name": "@1money/hooks",
  "version": "0.1.0",
  "description": "React hooks for 1money front-end projects",
  "main": "lib/index.js",
  "module": "es/index.js",
  "types": "es/index.d.ts",
  "sideEffects": false,
  "files": [
    "lib",
    "es"
  ],
  "exports": {
    ".": {
      "types": "./es/index.d.ts",
      "import": "./es/index.js",
      "require": "./lib/index.js"
    },
    "./useControlledState": {
      "types": "./es/useControlledState/index.d.ts",
      "import": "./es/useControlledState/index.js",
      "require": "./lib/useControlledState/index.js"
    },
    "./useEventCallback": {
      "types": "./es/useEventCallback/index.d.ts",
      "import": "./es/useEventCallback/index.js",
      "require": "./lib/useEventCallback/index.js"
    },
    "./useLatest": {
      "types": "./es/useLatest/index.d.ts",
      "import": "./es/useLatest/index.js",
      "require": "./lib/useLatest/index.js"
    },
    "./useLayoutEffect": {
      "types": "./es/useLayoutEffect/index.d.ts",
      "import": "./es/useLayoutEffect/index.js",
      "require": "./lib/useLayoutEffect/index.js"
    },
    "./useLayoutState": {
      "types": "./es/useLayoutState/index.d.ts",
      "import": "./es/useLayoutState/index.js",
      "require": "./lib/useLayoutState/index.js"
    },
    "./useMemoizedFn": {
      "types": "./es/useMemoizedFn/index.d.ts",
      "import": "./es/useMemoizedFn/index.js",
      "require": "./lib/useMemoizedFn/index.js"
    },
    "./usePrevious": {
      "types": "./es/usePrevious/index.d.ts",
      "import": "./es/usePrevious/index.js",
      "require": "./lib/usePrevious/index.js"
    },
    "./useSafeState": {
      "types": "./es/useSafeState/index.d.ts",
      "import": "./es/useSafeState/index.js",
      "require": "./lib/useSafeState/index.js"
    },
    "./useSyncState": {
      "types": "./es/useSyncState/index.d.ts",
      "import": "./es/useSyncState/index.js",
      "require": "./lib/useSyncState/index.js"
    },
    "./useUpdateEffect": {
      "types": "./es/useUpdateEffect/index.d.ts",
      "import": "./es/useUpdateEffect/index.js",
      "require": "./lib/useUpdateEffect/index.js"
    }
  },
  "scripts": {
    "build": "father build",
    "dev": "father dev",
    "test": "vitest run",
    "lint": "npm run lint:prettier && npm run lint:es",
    "lint:fix": "npm run lint:prettier_fix && npm run lint:es_fix",
    "lint:es": "eslint src/",
    "lint:es_fix": "eslint src/ --fix",
    "lint:prettier": "prettier --check src/",
    "lint:prettier_fix": "prettier --write src/"
  },
  "keywords": [],
  "author": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/1Money-Co/1money-hooks"
  },
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.19.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "~7.37.5",
    "father": "^4.6.17",
    "globals": "^15.15.0",
    "jsdom": "^29.0.2",
    "prettier": "~3.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.2.4",
    "typescript": "~5.5.4",
    "vite": "^8.0.5",
    "vitest": "^4.1.4"
  },
  "pnpm": {
    "overrides": {
      "@babel/runtime": "7.26.10",
      "@eslint/plugin-kit": "0.3.4",
      "@tootallnate/once": "3.0.1",
      "ajv@6.12.6": "6.14.0",
      "brace-expansion@2.0.2": "2.0.3",
      "esbuild": "0.25.0",
      "flatted": "3.4.2",
      "lodash": "4.18.0",
      "minimatch@3.0.8": "3.1.5",
      "minimatch@3.1.2": "3.1.5",
      "picomatch@2.3.1": "2.3.2",
      "picomatch@4.0.3": "4.0.4",
      "send": "0.19.0",
      "yaml": "1.10.3"
    }
  }
}
